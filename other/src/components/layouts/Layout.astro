                  ><li class="hover:bg-slate-300 rounded-sm p-2">About</li></a
                >

                <a href="/projects/"
                  ><li class="hover:bg-slate-300 rounded-sm p-2">
                    Projects
                  </li></a
                >

                <a href="/work/">
                  <li class="hover:bg-slate-300 rounded-sm p-2">Work</li></a
                >

                <a href="/interests/"
                  ><li class="hover:bg-slate-300 rounded-sm p-2">
                    Interests
                  </li></a
                >

                <li>
                  <a href="/contact/">
                    <button
                      class="bg-slate-200 rounded-sm p-2 text-slate-800 hover:bg-slate-300"
                      >Contact</button
                    >
                  </a>
                </li>
              </ul>
            </details>
          </li>
        </ul>

        <!-- Nav Links -->
        <ul
          class="flex-col justify-center items-center hidden md:flex md:flex-row self-center gap-4 font-semibold"
        >
          <a href="/"
            ><li class="hover:bg-slate-100/30 rounded-sm p-2">Home</li></a
          >

          <a href="/about/"
            ><li class="hover:bg-slate-100/30 rounded-sm p-2">About</li></a
          >

          <a href="/projects/"
            ><li class="hover:bg-slate-100/30 rounded-sm p-2">Projects</li></a
          >

          <a href="/work/">
            <li class="hover:bg-slate-100/30 rounded-sm p-2">Work</li></a
          >

          <a href="/interests/"
            ><li class="hover:bg-slate-100/30 rounded-sm p-2">Interests</li></a
          >

          <li>
            <a href="/contact/">
              <button
                class="bg-slate-200 rounded-sm p-2 text-slate-800 hover:bg-slate-300"
                >Contact</button
              >
            </a>
          </li><br />
        </ul>
      </nav>

      <!-- Slot/Code Replacement -->
      <slot />

      <!-- Footer -->
      <footer class="bg-slate-200 text-slate-800">
        <br /><br />
        <div class="p-2.5">
          <!-- Brand -->
          <div class="p-2.5 pb-4 mx-auto flex items-center justify-center">
            <!-- Logo -->
            <img
              class="inline-block w-10"
              src="/img/logo/LogoDark.svg"
              alt="logo"
            />

            <!-- Slogan -->
            <span class="relative -bottom-2 -right-2"
